@page "/taskboard"
@using BDAplication.Web.Authentication
@using BDAplication.Web.Models
@using BDAplication.Web.Services
@using BDAplication.Web.Components.TaskBoard
@using MudBlazor
@inject JwtAuthStateProvider AuthProvider
@inject NavigationManager Nav
@inject TaskBoardApiService TaskBoardApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<style>
    /* ── Board layout ──────────────────────────────────────── */
    .tb-page {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 112px);
        overflow: hidden;
    }

    .tb-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
        flex-shrink: 0;
    }

    .tb-board {
        display: flex;
        gap: 14px;
        overflow-x: auto;
        flex: 1;
        padding-bottom: 8px;
    }

    .tb-board::-webkit-scrollbar { height: 6px; }
    .tb-board::-webkit-scrollbar-thumb { background: rgba(0,0,0,.18); border-radius: 4px; }

    /* ── Column ─────────────────────────────────────────────── */
    .tb-column {
        flex: 0 0 280px;
        display: flex;
        flex-direction: column;
        border-radius: 10px;
        overflow: hidden;
        background: var(--mud-palette-surface);
        box-shadow: 0 2px 8px rgba(0,0,0,.10);
        transition: box-shadow .2s, transform .15s;
    }

    .tb-column-drag-over {
        box-shadow: 0 0 0 3px #1976d2, 0 4px 16px rgba(25,118,210,.25);
        transform: scale(1.015);
    }

    .tb-column-header {
        padding: 12px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .tb-column-header-content {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .tb-column-count {
        background: rgba(255,255,255,.25);
        color: white;
        font-weight: 700;
        font-size: .78rem;
        border-radius: 12px;
        padding: 2px 9px;
        min-width: 26px;
        text-align: center;
    }

    .tb-column-body {
        padding: 10px 10px 10px 10px;
        overflow-y: auto;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 10px;
        min-height: 80px;
    }

    .tb-column-body::-webkit-scrollbar { width: 4px; }
    .tb-column-body::-webkit-scrollbar-thumb { background: rgba(0,0,0,.15); border-radius: 4px; }

    .tb-column-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 30px 10px;
        pointer-events: none;
    }

    /* ── Card ───────────────────────────────────────────────── */
    .tb-card {
        background: var(--mud-palette-background);
        border-radius: 8px;
        padding: 12px 12px 10px;
        cursor: grab;
        box-shadow: 0 1px 4px rgba(0,0,0,.10);
        transition: box-shadow .15s, transform .15s, opacity .15s;
        user-select: none;
    }

    .tb-card:hover {
        box-shadow: 0 4px 14px rgba(0,0,0,.16);
        transform: translateY(-2px);
    }

    .tb-card-dragging {
        opacity: .45;
        transform: rotate(2deg) scale(.97);
        cursor: grabbing;
    }

    .tb-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 4px;
    }

    .tb-card-title {
        font-weight: 600;
        line-height: 1.3;
        flex: 1;
        word-break: break-word;
    }

    .tb-card-actions {
        display: flex;
        flex-shrink: 0;
        margin-top: -4px;
        margin-right: -6px;
    }

    .tb-card-desc {
        margin-top: 6px;
        font-size: .82rem;
        line-height: 1.4;
        word-break: break-word;
    }

    .tb-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 10px;
    }

    .tb-priority-chip {
        font-size: .68rem;
        font-weight: 700;
        color: white;
        padding: 2px 8px;
        border-radius: 10px;
        letter-spacing: .4px;
        text-transform: uppercase;
    }

    /* ── Subtask progress bar ────────────────────────────────── */
    .tb-subtask-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        margin-top: 8px;
    }

    .tb-subtask-track {
        flex: 1;
        height: 4px;
        background: rgba(0,0,0,.10);
        border-radius: 4px;
        overflow: hidden;
    }

    .tb-subtask-fill {
        height: 100%;
        border-radius: 4px;
        transition: width .3s ease;
    }

    .tb-subtask-label {
        font-size: .68rem;
        font-weight: 600;
        opacity: .65;
        white-space: nowrap;
    }
</style>

<div class="tb-page">

    <!-- Top bar -->
    <div class="tb-topbar">
        <div style="display:flex;align-items:center;gap:10px">
            <MudIcon Icon="@Icons.Material.Filled.ViewKanban"
                     Style="font-size:28px;color:var(--mud-palette-primary)" />
            <MudText Typo="Typo.h5" Style="font-weight:700">Task Board</MudText>
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
            }
        </div>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog"
                   Disabled="_loading">
            Nueva Tarea
        </MudButton>
    </div>

    <!-- Kanban board -->
    <div class="tb-board">
        @foreach (var col in _columns)
        {
            <TaskColumn Status="@col.Status"
                        Label="@col.Label"
                        Tasks="@GetTasksByStatus(col.Status)"
                        DraggingTaskId="@_draggingTaskId"
                        OnDragStart="@OnCardDragStart"
                        OnDragEnd="@OnCardDragEnd"
                        OnDrop="@OnColumnDrop"
                        OnEdit="@OpenEditDialog"
                        OnDelete="@ConfirmDelete" />
        }
    </div>
</div>

@code {
    private bool _loading = true;
    private List<TaskBoardModel> _tasks = new();
    private int _draggingTaskId;

    private static readonly (TaskBoardStatus Status, string Label)[] _columns =
    [
        (TaskBoardStatus.Pending,    "PENDIENTE"),
        (TaskBoardStatus.InProgress, "EN CURSO"),
        (TaskBoardStatus.Suspended,  "SUSPENDIDO"),
        (TaskBoardStatus.Cancelled,  "ANULADO"),
        (TaskBoardStatus.Completed,  "COMPLETADO"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var auth = await AuthProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var resp = await TaskBoardApi.GetTasksAsync();
            _tasks = resp?.Data ?? new List<TaskBoardModel>();
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private List<TaskBoardModel> GetTasksByStatus(TaskBoardStatus status) =>
        _tasks.Where(t => t.Status == status).ToList();

    // ── Drag & Drop ──────────────────────────────────────────
    private void OnCardDragStart(int taskId) => _draggingTaskId = taskId;
    private void OnCardDragEnd() => _draggingTaskId = 0;

    private async Task OnColumnDrop(TaskBoardStatus targetStatus)
    {
        if (_draggingTaskId == 0) return;

        var taskId = _draggingTaskId;
        _draggingTaskId = 0;

        var task = _tasks.FirstOrDefault(t => t.Id == taskId);
        if (task is null || task.Status == targetStatus) return;

        var prevStatus = task.Status;
        task.Status = targetStatus;
        StateHasChanged();

        var resp = await TaskBoardApi.MoveAsync(new MoveTaskBoardRequest
        {
            TaskId = taskId,
            Status = targetStatus
        });

        if (resp?.Success == true)
        {
            Snackbar.Add($"Tarea movida a «{StatusLabel(targetStatus)}»", Severity.Success);
        }
        else
        {
            task.Status = prevStatus;
            Snackbar.Add("Error al mover la tarea", Severity.Error);
            StateHasChanged();
        }
    }

    // ── Crear ────────────────────────────────────────────────
    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateTaskDialog>("Nueva Tarea",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });

        var result = await dialog.Result;
        if (result?.Canceled == true || result?.Data is not CreateTaskBoardRequest req) return;

        var resp = await TaskBoardApi.CreateAsync(req);
        if (resp?.Success == true && resp.Data is not null)
        {
            _tasks.Add(resp.Data);
            Snackbar.Add("Tarea creada correctamente", Severity.Success);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Error al crear la tarea", Severity.Error);
        }
    }

    // ── Editar ───────────────────────────────────────────────
    private async Task OpenEditDialog(TaskBoardModel task)
    {
        var parameters = new DialogParameters<EditTaskDialog> { { x => x.Task, task } };
        var dialog = await DialogService.ShowAsync<EditTaskDialog>("Editar Tarea", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });

        var result = await dialog.Result;
        if (result?.Canceled == true || result?.Data is not UpdateTaskBoardRequest req) return;

        var resp = await TaskBoardApi.UpdateAsync(req);
        if (resp?.Success == true && resp.Data is not null)
        {
            var idx = _tasks.FindIndex(t => t.Id == resp.Data.Id);
            if (idx >= 0) _tasks[idx] = resp.Data;
            Snackbar.Add("Tarea actualizada", Severity.Success);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Error al actualizar la tarea", Severity.Error);
        }
    }

    // ── Eliminar ─────────────────────────────────────────────
    private async Task ConfirmDelete(int taskId)
    {
        var confirm = await DialogService.ShowMessageBox(
            "Eliminar tarea",
            "¿Deseas eliminar esta tarea? La acción no se puede deshacer.",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (confirm != true) return;

        var resp = await TaskBoardApi.DeleteTaskAsync(taskId);
        if (resp?.Success == true)
        {
            _tasks.RemoveAll(t => t.Id == taskId);
            Snackbar.Add("Tarea eliminada", Severity.Success);
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("Error al eliminar la tarea", Severity.Error);
        }
    }

    private static string StatusLabel(TaskBoardStatus s) => s switch
    {
        TaskBoardStatus.Pending    => "Pendiente",
        TaskBoardStatus.InProgress => "En Curso",
        TaskBoardStatus.Suspended  => "Suspendido",
        TaskBoardStatus.Cancelled  => "Anulado",
        TaskBoardStatus.Completed  => "Completado",
        _                          => s.ToString()
    };
}
