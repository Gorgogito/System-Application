@page "/roles"
@using BDAplication.Web.Models
@using BDAplication.Web.Services
@inject RoleApiService RoleApi
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject JwtAuthStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>Roles - BDAplication</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h5">Gestión de Roles</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog">
            Nuevo Rol
        </MudButton>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else
    {
        <MudPaper Elevation="3" Style="border-radius:12px;overflow:hidden">
            <MudTable Items="_roles" Hover="true" Striped="true" Dense="true"
                      Filter="FilterFunc" @bind-SelectedItem="_selectedRole">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Roles</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchText" Placeholder="Buscar..."
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium" Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>Nombre</MudTh>
                    <MudTh>Descripción</MudTh>
                    <MudTh>Estado</MudTh>
                    <MudTh>Creado</MudTh>
                    <MudTh>Acciones</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Id</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="Color.Primary" Size="Size.Small">
                            @context.Name
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.Description</MudTd>
                    <MudTd>
                        <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                            @(context.IsActive ? "Activo" : "Inactivo")
                        </MudChip>
                    </MudTd>
                    <MudTd>@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Warning" OnClick="() => OpenEditDialog(context)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                       Color="Color.Error" OnClick="() => ConfirmDelete(context)" />
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText>No hay roles registrados.</MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    }

    <!-- Dialog Crear/Editar -->
    <MudDialog @bind-Visible="_dialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">
                @(_isEditing ? "Editar Rol" : "Nuevo Rol")
            </MudText>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudTextField @bind-Value="_formName" Label="Nombre" Variant="Variant.Outlined"
                              Required="true" RequiredError="El nombre es requerido" />
                <MudTextField @bind-Value="_formDescription" Label="Descripción"
                              Variant="Variant.Outlined" Lines="3" />
                @if (_isEditing)
                {
                    <MudSwitch @bind-Value="_formIsActive" Color="Color.Primary" Label="Activo" />
                }
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="() => _dialogOpen = false">Cancelar</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="SaveAsync" Disabled="_saving">
                @(_saving ? "Guardando..." : "Guardar")
            </MudButton>
        </DialogActions>
    </MudDialog>
</MudContainer>

@code {
    private List<RoleModel> _roles = new();
    private RoleModel? _selectedRole;
    private bool _loading = true;
    private bool _dialogOpen;
    private bool _isEditing;
    private bool _saving;
    private string _searchText = string.Empty;

    private string _formName = string.Empty;
    private string _formDescription = string.Empty;
    private bool _formIsActive = true;
    private int _editingId;

    private DialogOptions _dialogOptions = new()
    {
        CloseButton = true,
        MaxWidth = MaxWidth.Small,
        FullWidth = true
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        var state = await AuthProvider.GetAuthenticationStateAsync();
        if (!state.User.Identity?.IsAuthenticated ?? true)
        {
            Nav.NavigateTo("/login");
            return;
        }
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        try
        {
            var result = await RoleApi.GetAllAsync();
            _roles = result?.Data?.ToList() ?? new();
        }
        catch { Snackbar.Add("Error al cargar roles", Severity.Error); }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private bool FilterFunc(RoleModel r) =>
        string.IsNullOrWhiteSpace(_searchText) ||
        r.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
        r.Description.Contains(_searchText, StringComparison.OrdinalIgnoreCase);

    private void OpenCreateDialog()
    {
        _isEditing = false;
        _formName = string.Empty;
        _formDescription = string.Empty;
        _formIsActive = true;
        _dialogOpen = true;
    }

    private void OpenEditDialog(RoleModel role)
    {
        _isEditing = true;
        _editingId = role.Id;
        _formName = role.Name;
        _formDescription = role.Description;
        _formIsActive = role.IsActive;
        _dialogOpen = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_formName))
        {
            Snackbar.Add("El nombre es requerido", Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            if (_isEditing)
            {
                var result = await RoleApi.UpdateAsync(new UpdateRoleModel
                {
                    Id = _editingId, Name = _formName,
                    Description = _formDescription, IsActive = _formIsActive
                });
                if (result?.Success == true)
                {
                    Snackbar.Add("Rol actualizado", Severity.Success);
                    _dialogOpen = false;
                    await LoadAsync();
                }
                else Snackbar.Add(result?.Message ?? "Error al actualizar", Severity.Error);
            }
            else
            {
                var result = await RoleApi.CreateAsync(new CreateRoleModel
                    { Name = _formName, Description = _formDescription });
                if (result?.Success == true)
                {
                    Snackbar.Add("Rol creado", Severity.Success);
                    _dialogOpen = false;
                    await LoadAsync();
                }
                else Snackbar.Add(result?.Message ?? "Error al crear", Severity.Error);
            }
        }
        catch { Snackbar.Add("Error de conexión", Severity.Error); }
        finally { _saving = false; }
    }

    private async Task ConfirmDelete(RoleModel role)
    {
        var result = await DialogService.ShowMessageBox(
            "Eliminar Rol",
            $"¿Deseas eliminar el rol '{role.Name}'?",
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            var response = await RoleApi.DeleteAsync(role.Id);
            if (response?.Success == true)
            {
                Snackbar.Add("Rol eliminado", Severity.Success);
                await LoadAsync();
            }
            else Snackbar.Add(response?.Message ?? "Error al eliminar", Severity.Error);
        }
    }
}
